{
  "name": "@odontocare/desktop",
  "version": "1.0.0",
  "description": "Sistema odontologico desktop profesional y offline.",
  "author": "OdontoCare",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c green,blue \"vite --host 127.0.0.1\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:electron && wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "build": "tsc --noEmit -p tsconfig.json && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "build": {
    "appId": "com.odontocare.desktop",
    "productName": "OdontoCare",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime",
        "filter": [
          "api/**/*",
          "database/**/*",
          "runtime-manifest.json"
        ]
      },
      {
        "from": "runtime/node_modules/@prisma/client",
        "to": "runtime/node_modules/@prisma/client"
      },
      {
        "from": "runtime/node_modules/.prisma/client",
        "to": "runtime/node_modules/.prisma/client"
      },
      {
        "from": "../../vendor/postgresql",
        "to": "postgresql"
      }
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "OdontoCare-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "perMachine": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.1",
    "cross-env": "^10.1.0",
    "electron": "42.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.15",
    "wait-on": "^9.0.10"
  }
}
