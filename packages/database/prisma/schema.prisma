generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DENTIST
  RECEPTION
}

enum Gender {
  FEMALE
  MALE
  OTHER
  UNSPECIFIED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ClinicalEntryType {
  CONSULTATION
  EVOLUTION
  PRESCRIPTION
  PROCEDURE
  NOTE
}

enum ToothStatus {
  HEALTHY
  CARIES
  RESTORATION
  EXTRACTION
  IMPLANT
  COMPLETED_TREATMENT
}

enum TreatmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  INSURANCE
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  VOID
}

enum MediaType {
  IMAGE
  XRAY
  PDF
  DOCUMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  RESTORE
  EXPORT
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BackupFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum BackupOperation {
  BACKUP
  RESTORE
}

enum BackupSource {
  MANUAL
  AUTOMATIC
  IMPORTED
  SAFETY
}

enum InventoryItemType {
  CONSUMABLE
  MATERIAL
  MEDICATION
  INSTRUMENT
  OTHER
}

enum InventoryMovementType {
  PURCHASE
  CONSUMPTION
  RETURN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  EXPIRED
  DAMAGED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(180)
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name") @db.VarChar(160)
  role         UserRole
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  auditLogs            AuditLog[]          @relation("audit_actor")
  appointmentsAsDoctor Appointment[]       @relation("appointment_doctor")
  appointmentsCreated  Appointment[]       @relation("appointment_creator")
  clinicalEntries      ClinicalEntry[]     @relation("clinical_entry_author")
  mediaUploads         MediaAsset[]        @relation("media_uploader")
  paymentsCreated      Payment[]           @relation("payment_creator")
  patientsCreated      Patient[]           @relation("patient_creator")
  toothEvents          ToothEvent[]        @relation("tooth_event_author")
  treatmentsAsDoctor   Treatment[]         @relation("treatment_doctor")
  backupJobs           BackupJob[]         @relation("backup_actor")
  inventoryMovements   InventoryMovement[] @relation("inventory_movement_actor")

  @@index([role, isActive])
  @@map("users")
}

model Patient {
  id                    String    @id @default(uuid()) @db.Uuid
  code                  String    @unique @db.VarChar(24)
  firstName             String    @map("first_name") @db.VarChar(120)
  lastName              String    @map("last_name") @db.VarChar(120)
  documentId            String?   @unique @map("document_id") @db.VarChar(40)
  birthDate             DateTime? @map("birth_date")
  gender                Gender    @default(UNSPECIFIED)
  phone                 String?   @db.VarChar(40)
  email                 String?   @db.VarChar(180)
  address               String?   @db.VarChar(240)
  occupation            String?   @db.VarChar(120)
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(160)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(40)
  allergies             String?
  medicalAlerts         String?   @map("medical_alerts")
  notes                 String?
  createdById           String?   @map("created_by_id") @db.Uuid
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  appointments    Appointment[]
  clinicalEntries ClinicalEntry[]
  createdBy       User?             @relation("patient_creator", fields: [createdById], references: [id], onDelete: SetNull)
  media           MediaAsset[]
  odontogram      OdontogramTooth[]
  payments        Payment[]
  toothEvents     ToothEvent[]
  treatments      Treatment[]

  @@index([lastName, firstName])
  @@index([phone])
  @@index([deletedAt])
  @@map("patients")
}

model ClinicalEntry {
  id        String            @id @default(uuid()) @db.Uuid
  patientId String            @map("patient_id") @db.Uuid
  authorId  String?           @map("author_id") @db.Uuid
  type      ClinicalEntryType
  title     String            @db.VarChar(160)
  notes     String
  metadata  Json?
  deletedAt DateTime?         @map("deleted_at")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  author  User?   @relation("clinical_entry_author", fields: [authorId], references: [id], onDelete: SetNull)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@map("clinical_entries")
}

model Appointment {
  id          String            @id @default(uuid()) @db.Uuid
  patientId   String            @map("patient_id") @db.Uuid
  doctorId    String?           @map("doctor_id") @db.Uuid
  createdById String?           @map("created_by_id") @db.Uuid
  title       String            @db.VarChar(160)
  status      AppointmentStatus @default(PENDING)
  startsAt    DateTime          @map("starts_at")
  endsAt      DateTime          @map("ends_at")
  color       String?           @db.VarChar(24)
  notes       String?
  deletedAt   DateTime?         @map("deleted_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  createdBy User?   @relation("appointment_creator", fields: [createdById], references: [id], onDelete: SetNull)
  doctor    User?   @relation("appointment_doctor", fields: [doctorId], references: [id], onDelete: SetNull)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId, startsAt])
  @@index([patientId, startsAt])
  @@index([status, startsAt])
  @@map("appointments")
}

model Treatment {
  id            String          @id @default(uuid()) @db.Uuid
  patientId     String          @map("patient_id") @db.Uuid
  doctorId      String?         @map("doctor_id") @db.Uuid
  toothNumber   Int?            @map("tooth_number")
  name          String          @db.VarChar(160)
  description   String?
  status        TreatmentStatus @default(PLANNED)
  estimatedCost Decimal?        @map("estimated_cost") @db.Decimal(12, 2)
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  deletedAt     DateTime?       @map("deleted_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  doctor      User?        @relation("treatment_doctor", fields: [doctorId], references: [id], onDelete: SetNull)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments    Payment[]
  toothEvents ToothEvent[]

  @@index([patientId, status])
  @@index([doctorId, status])
  @@map("treatments")
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  patientId   String        @map("patient_id") @db.Uuid
  treatmentId String?       @map("treatment_id") @db.Uuid
  createdById String?       @map("created_by_id") @db.Uuid
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  status      PaymentStatus @default(PAID)
  reference   String?       @db.VarChar(120)
  notes       String?
  paidAt      DateTime      @default(now()) @map("paid_at")
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  createdBy User?      @relation("payment_creator", fields: [createdById], references: [id], onDelete: SetNull)
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([patientId, paidAt])
  @@index([status, paidAt])
  @@map("payments")
}

model OdontogramTooth {
  id          String      @id @default(uuid()) @db.Uuid
  patientId   String      @map("patient_id") @db.Uuid
  toothNumber Int         @map("tooth_number")
  status      ToothStatus @default(HEALTHY)
  notes       String?
  updatedById String?     @map("updated_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, toothNumber])
  @@index([patientId, status])
  @@map("odontogram_teeth")
}

model ToothEvent {
  id          String      @id @default(uuid()) @db.Uuid
  patientId   String      @map("patient_id") @db.Uuid
  treatmentId String?     @map("treatment_id") @db.Uuid
  authorId    String?     @map("author_id") @db.Uuid
  toothNumber Int         @map("tooth_number")
  status      ToothStatus
  notes       String?
  createdAt   DateTime    @default(now()) @map("created_at")

  author    User?      @relation("tooth_event_author", fields: [authorId], references: [id], onDelete: SetNull)
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([patientId, toothNumber, createdAt])
  @@map("tooth_events")
}

model MediaAsset {
  id           String    @id @default(uuid()) @db.Uuid
  patientId    String    @map("patient_id") @db.Uuid
  uploadedById String?   @map("uploaded_by_id") @db.Uuid
  type         MediaType
  label        String?   @db.VarChar(160)
  filePath     String    @map("file_path")
  mimeType     String    @map("mime_type") @db.VarChar(120)
  sizeBytes    Int?      @map("size_bytes")
  capturedAt   DateTime? @map("captured_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("media_uploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([patientId, type, createdAt])
  @@map("media_assets")
}

model AuditLog {
  id        String      @id @default(uuid()) @db.Uuid
  actorId   String?     @map("actor_id") @db.Uuid
  action    AuditAction
  entity    String      @db.VarChar(120)
  entityId  String?     @map("entity_id") @db.VarChar(120)
  before    Json?
  after     Json?
  ipAddress String?     @map("ip_address") @db.VarChar(80)
  createdAt DateTime    @default(now()) @map("created_at")

  actor User? @relation("audit_actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model BackupJob {
  id              String          @id @default(uuid()) @db.Uuid
  operation       BackupOperation @default(BACKUP)
  source          BackupSource    @default(MANUAL)
  status          BackupStatus    @default(PENDING)
  filePath        String?         @map("file_path")
  fileName        String?         @map("file_name") @db.VarChar(240)
  sizeBytes       BigInt?         @map("size_bytes")
  includesUploads Boolean         @default(true) @map("includes_uploads")
  errorMessage    String?         @map("error_message")
  actorId         String?         @map("actor_id") @db.Uuid
  startedAt       DateTime?       @map("started_at")
  finishedAt      DateTime?       @map("finished_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  actor User? @relation("backup_actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([operation, status, createdAt])
  @@index([source, createdAt])
  @@map("backup_jobs")
}

model BackupSettings {
  id                    String          @id @default("primary") @db.VarChar(32)
  backupDirectory       String          @default("C:/OdontoSystem/backups") @map("backup_directory")
  automaticEnabled      Boolean         @default(true) @map("automatic_enabled")
  frequency             BackupFrequency @default(DAILY)
  scheduledHour         Int             @default(2) @map("scheduled_hour")
  includeUploads        Boolean         @default(true) @map("include_uploads")
  retentionCount        Int             @default(14) @map("retention_count")
  lastAutomaticBackupAt DateTime?       @map("last_automatic_backup_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@map("backup_settings")
}

model Supplier {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(180)
  taxId       String?   @map("tax_id") @db.VarChar(60)
  contactName String?   @map("contact_name") @db.VarChar(160)
  phone       String?   @db.VarChar(40)
  email       String?   @db.VarChar(180)
  address     String?   @db.VarChar(240)
  notes       String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items     InventoryItem[]
  movements InventoryMovement[]

  @@index([name])
  @@index([deletedAt])
  @@map("suppliers")
}

model InventoryItem {
  id           String            @id @default(uuid()) @db.Uuid
  supplierId   String?           @map("supplier_id") @db.Uuid
  sku          String?           @unique @db.VarChar(80)
  name         String            @db.VarChar(180)
  type         InventoryItemType
  description  String?
  unit         String            @db.VarChar(40)
  location     String?           @db.VarChar(120)
  currentStock Decimal           @default(0) @map("current_stock") @db.Decimal(14, 3)
  minimumStock Decimal           @default(0) @map("minimum_stock") @db.Decimal(14, 3)
  unitCost     Decimal           @default(0) @map("unit_cost") @db.Decimal(14, 2)
  deletedAt    DateTime?         @map("deleted_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  supplier  Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@index([name, type])
  @@index([supplierId])
  @@index([deletedAt])
  @@map("inventory_items")
}

model InventoryMovement {
  id             String                @id @default(uuid()) @db.Uuid
  itemId         String                @map("item_id") @db.Uuid
  supplierId     String?               @map("supplier_id") @db.Uuid
  actorId        String?               @map("actor_id") @db.Uuid
  type           InventoryMovementType
  quantity       Decimal               @db.Decimal(14, 3)
  previousStock  Decimal               @map("previous_stock") @db.Decimal(14, 3)
  resultingStock Decimal               @map("resulting_stock") @db.Decimal(14, 3)
  unitCost       Decimal?              @map("unit_cost") @db.Decimal(14, 2)
  reference      String?               @db.VarChar(140)
  notes          String?
  createdAt      DateTime              @default(now()) @map("created_at")

  actor    User?         @relation("inventory_movement_actor", fields: [actorId], references: [id], onDelete: SetNull)
  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  supplier Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
  @@index([type, createdAt])
  @@index([supplierId, createdAt])
  @@map("inventory_movements")
}

model ClinicSettings {
  id                     String   @id @default("primary") @db.VarChar(32)
  clinicName             String   @default("OdontoCare") @map("clinic_name") @db.VarChar(160)
  taxId                  String?  @map("tax_id") @db.VarChar(40)
  phone                  String?  @db.VarChar(40)
  email                  String?  @db.VarChar(180)
  address                String?  @db.VarChar(240)
  currency               String   @default("USD") @db.VarChar(8)
  timezone               String   @default("America/Guayaquil") @db.VarChar(80)
  appointmentDurationMin Int      @default(30) @map("appointment_duration_min")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("clinic_settings")
}
